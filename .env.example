# ── OU7 environment ──────────────────────────────────────────
# Copy to `.env` for local dev. Never commit real secrets.

# App
NODE_ENV=development
TZ=Asia/Dubai

# Database (local docker-compose Postgres by default)
DATABASE_URL="postgresql://ou7:ou7@localhost:5432/ou7?schema=public"

# Auth.js (all required — the app fails fast if any is missing)
AUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google Workspace SSO (domain-restricted) — required
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
# Only accounts on this domain may sign in:
ALLOWED_EMAIL_DOMAIN="interestingtimes.me"

# Notifications — email (transactional)
SMTP_URL=""
MAIL_FROM="OU7 <leave@interestingtimes.me>"

# Notifications — Microsoft Teams (Graph API, direct messages) — Phase 1 flag
TEAMS_ENABLED="false"
MS_GRAPH_TENANT_ID=""
MS_GRAPH_CLIENT_ID=""
MS_GRAPH_CLIENT_SECRET=""

# Notion export (one-way, output only)
NOTION_EXPORT_ENABLED="false"
NOTION_TOKEN=""
NOTION_DATABASE_ID=""
